# 环境变量配置
# 复制此文件为 .env 并填入真实值

# 服务端口
PORT=3000

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=health_station

# 阿里云 OSS（用于 PDF/视频上传）
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_ak_id
OSS_ACCESS_KEY_SECRET=your_ak_secret
OSS_BUCKET=health-station-files
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_CDN_BASE=https://cdn.example.com   # 如使用 CDN 加速

# 调试模式
DEBUG=false
